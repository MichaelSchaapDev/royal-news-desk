<Application
  x:Class="RoyalNewsDesk.App.App"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:vm="clr-namespace:RoyalNewsDesk.App.ViewModels"
  xmlns:views="clr-namespace:RoyalNewsDesk.App.Views"
  xmlns:conv="clr-namespace:RoyalNewsDesk.App.Converters">
  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ui:ThemesDictionary Theme="Light" />
        <ui:ControlsDictionary />
      </ResourceDictionary.MergedDictionaries>

      <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
      <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility" />
      <conv:CountToVisibilityConverter x:Key="CountToVisibility" />
      <conv:InverseBoolConverter x:Key="InverseBool" />

      <DataTemplate DataType="{x:Type vm:EpisodesViewModel}">
        <views:EpisodesView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:EditorViewModel}">
        <views:EditorView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
        <views:SettingsView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:AboutViewModel}">
        <views:AboutView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:FirstRunViewModel}">
        <views:FirstRunView />
      </DataTemplate>
      <DataTemplate DataType="{x:Type vm:ProduceViewModel}">
        <views:ProduceView />
      </DataTemplate>
    </ResourceDictionary>
  </Application.Resources>
</Application>
