<ui:FluentWindow
  x:Class="RoyalNewsDesk.App.MainWindow"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:res="clr-namespace:RoyalNewsDesk.App.Resources"
  xmlns:vm="clr-namespace:RoyalNewsDesk.App.ViewModels"
  Title="{x:Static res:Strings.App_Title}"
  Width="1240"
  Height="800"
  MinWidth="960"
  MinHeight="640"
  Background="{DynamicResource ApplicationBackgroundBrush}"
  ExtendsContentIntoTitleBar="True"
  WindowBackdropType="None"
  WindowCornerPreference="Round"
  WindowStartupLocation="CenterScreen">
  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="248" />
      <ColumnDefinition Width="*" />
    </Grid.ColumnDefinitions>

    <!-- Brand sidebar: navy in both themes; the studio identity lives here. -->
    <Border Grid.Column="0">
      <Border.Background>
        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
          <GradientStop Offset="0" Color="#1D2C55" />
          <GradientStop Offset="1" Color="#131F3E" />
        </LinearGradientBrush>
      </Border.Background>
      <DockPanel Margin="14,20,14,16">

        <!-- Wordmark -->
        <StackPanel DockPanel.Dock="Top" Margin="12,2,8,26" Orientation="Horizontal">
          <Path
            Width="22"
            Height="20"
            VerticalAlignment="Center"
            Data="{StaticResource CrownGeometry}"
            Fill="{StaticResource BrandGoldBrush}"
            Stretch="Uniform" />
          <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
            <TextBlock
              FontFamily="{DynamicResource DisplayFontFamily}"
              FontSize="16"
              FontWeight="Medium"
              Foreground="{StaticResource SidebarTextBrush}"
              Text="{x:Static res:Strings.Brand_Name}" />
            <TextBlock
              FontSize="10"
              FontWeight="SemiBold"
              Foreground="{StaticResource BrandGoldBrush}"
              Text="{x:Static res:Strings.Brand_Studio}"
              Typography.Capitals="AllSmallCaps" />
          </StackPanel>
        </StackPanel>

        <!-- Version + update at the bottom -->
        <StackPanel DockPanel.Dock="Bottom">
          <ui:Button
            Margin="0,10,0,8"
            HorizontalAlignment="Stretch"
            Background="{StaticResource BrandGoldBrush}"
            Command="{Binding ApplyUpdateCommand}"
            Content="{x:Static res:Strings.Update_Restart}"
            Foreground="#182448"
            Icon="{ui:SymbolIcon ArrowSync24}"
            Visibility="{Binding UpdateReady, Converter={StaticResource BoolToVisibility}}" />
          <TextBlock
            Margin="12,0,0,2"
            FontSize="11"
            Foreground="{StaticResource SidebarTextDimBrush}"
            Text="{Binding VersionText}" />
        </StackPanel>

        <!-- Navigation -->
        <ListBox
          Background="Transparent"
          BorderThickness="0"
          ItemsSource="{Binding NavItems}"
          KeyboardNavigation.DirectionalNavigation="Cycle"
          ScrollViewer.HorizontalScrollBarVisibility="Disabled"
          SelectedItem="{Binding SelectedNavItem}">
          <ListBox.ItemContainerStyle>
            <Style TargetType="ListBoxItem">
              <Setter Property="Margin" Value="0,2" />
              <Setter Property="Padding" Value="0" />
              <Setter Property="HorizontalContentAlignment" Value="Stretch" />
              <Setter Property="Foreground" Value="{StaticResource SidebarTextDimBrush}" />
              <Setter Property="FocusVisualStyle" Value="{x:Null}" />
              <Setter Property="Template">
                <Setter.Value>
                  <ControlTemplate TargetType="ListBoxItem">
                    <Border
                      x:Name="Pill"
                      Background="Transparent"
                      CornerRadius="8">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="Auto" />
                          <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Rectangle
                          x:Name="Indicator"
                          Grid.Column="0"
                          Width="3"
                          Height="18"
                          Margin="4,0,0,0"
                          Fill="{StaticResource BrandGoldBrush}"
                          Opacity="0"
                          RadiusX="1.5"
                          RadiusY="1.5" />
                        <ContentPresenter Grid.Column="1" Margin="9,10,12,10" />
                      </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Pill" Property="Background" Value="{StaticResource SidebarHoverBrush}" />
                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
                      </Trigger>
                      <Trigger Property="IsSelected" Value="True">
                        <Setter TargetName="Pill" Property="Background" Value="{StaticResource SidebarSelectedBrush}" />
                        <Setter TargetName="Indicator" Property="Opacity" Value="1" />
                        <Setter Property="Foreground" Value="{StaticResource SidebarTextBrush}" />
                      </Trigger>
                      <Trigger Property="IsKeyboardFocusWithin" Value="True">
                        <Setter TargetName="Pill" Property="Background" Value="{StaticResource SidebarSelectedBrush}" />
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </Setter.Value>
              </Setter>
            </Style>
          </ListBox.ItemContainerStyle>
          <ListBox.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:NavItem}">
              <StackPanel Orientation="Horizontal">
                <ui:SymbolIcon
                  VerticalAlignment="Center"
                  FontSize="17"
                  Symbol="{Binding Icon}" />
                <TextBlock
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  FontSize="13.5"
                  FontWeight="SemiBold"
                  Text="{Binding Label}" />
              </StackPanel>
            </DataTemplate>
          </ListBox.ItemTemplate>
        </ListBox>
      </DockPanel>
    </Border>

    <!-- Content column with its own title bar row -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>
      <ui:TitleBar Grid.Row="0" ShowMaximize="True" ShowMinimize="True" />
      <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" />
    </Grid>
  </Grid>
</ui:FluentWindow>
