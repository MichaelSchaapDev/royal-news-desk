  <SolidColorBrush x:Key="GoldAccentSoftBrush" Color="#26C9A227" />
  <SolidColorBrush x:Key="StatusGoodBrush" Color="#58C287" />
  <SolidColorBrush x:Key="StatusGoodSoftBrush" Color="#2258C287" />
