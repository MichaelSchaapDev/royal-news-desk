<UserControl
  x:Class="RoyalNewsDesk.App.Views.EditorView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:res="clr-namespace:RoyalNewsDesk.App.Resources"
  xmlns:vm="clr-namespace:RoyalNewsDesk.App.ViewModels"
  x:Name="Root"
  TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
  <UserControl.Resources>
    <!-- Presenter choice as a selectable tile -->
    <Style x:Key="PresenterTile" TargetType="RadioButton">
      <Setter Property="Cursor" Value="Hand" />
      <Setter Property="Margin" Value="0,0,10,0" />
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="RadioButton">
            <Border
              x:Name="Tile"
              Padding="16,12"
              Background="{DynamicResource ControlFillColorDefaultBrush}"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1.2"
              CornerRadius="8">
              <ContentPresenter />
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Tile" Property="Background" Value="{DynamicResource CardHoverBrush}" />
              </Trigger>
              <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Tile" Property="BorderBrush" Value="{DynamicResource GoldAccentBrush}" />
                <Setter TargetName="Tile" Property="Background" Value="{DynamicResource GoldAccentSoftBrush}" />
              </Trigger>
              <Trigger Property="IsKeyboardFocused" Value="True">
                <Setter TargetName="Tile" Property="BorderThickness" Value="2" />
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>
  </UserControl.Resources>

  <Grid Margin="44,22,44,0">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto" />
      <RowDefinition Height="*" />
    </Grid.RowDefinitions>

    <!-- Action bar -->
    <Grid
      Grid.Row="0"
      MaxWidth="{StaticResource ContentMaxWidth}"
      Margin="0,0,0,18">
      <ui:Button
        Appearance="Transparent"
        Command="{Binding GoBackCommand}"
        Content="{x:Static res:Strings.Common_Back}"
        Icon="{ui:SymbolIcon ArrowLeft24}" />
      <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
        <ui:Button
          Margin="0,0,8,0"
          Command="{Binding SaveEditsCommand}"
          Content="{x:Static res:Strings.Common_Save}"
          Icon="{ui:SymbolIcon Save24}" />
        <ui:Button
          Appearance="Primary"
          Command="{Binding ProduceCommand}"
          Content="{x:Static res:Strings.Editor_Produce}"
          Icon="{ui:SymbolIcon Play24}" />
      </StackPanel>
    </Grid>

    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
      <StackPanel
        MaxWidth="{StaticResource ContentMaxWidth}"
        Margin="0,0,0,44"
        HorizontalAlignment="Stretch">

        <!-- Episode card: title + presenter -->
        <Border Style="{StaticResource CardBorder}">
          <StackPanel>
            <TextBlock Style="{StaticResource FieldLabelBase}" Text="{x:Static res:Strings.Editor_TitleLabel}" />
            <ui:TextBox
              FontSize="15"
              PlaceholderText="{x:Static res:Strings.Editor_TitlePlaceholder}"
              Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" />

            <TextBlock
              Margin="1,18,0,6"
              Style="{StaticResource FieldLabelBase}"
              Text="{x:Static res:Strings.Editor_PresenterStyle}" />
            <StackPanel Orientation="Horizontal">
              <RadioButton
                GroupName="PresenterStyle"
                IsChecked="{Binding IsPhotoreal, Converter={StaticResource InverseBool}}"
                Style="{StaticResource PresenterTile}">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon
                    VerticalAlignment="Center"
                    FontSize="19"
                    Foreground="{DynamicResource GoldAccentBrush}"
                    Symbol="VideoPerson24" />
                  <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="{x:Static res:Strings.Editor_PresenterAnimated}" />
                </StackPanel>
              </RadioButton>
              <RadioButton
                GroupName="PresenterStyle"
                IsChecked="{Binding IsPhotoreal}"
                Style="{StaticResource PresenterTile}">
                <StackPanel Orientation="Horizontal">
                  <ui:SymbolIcon
                    VerticalAlignment="Center"
                    FontSize="19"
                    Foreground="{DynamicResource GoldAccentBrush}"
                    Symbol="Camera24" />
                  <TextBlock
                    Margin="10,0,0,0"
                    VerticalAlignment="Center"
                    FontWeight="SemiBold"
                    Text="{x:Static res:Strings.Editor_PresenterPhotoreal}" />
                </StackPanel>
              </RadioButton>
            </StackPanel>

            <Border
              Margin="0,12,0,0"
              Padding="14,10"
              Background="{DynamicResource GoldAccentSoftBrush}"
              CornerRadius="8"
              Visibility="{Binding PhotorealNotReady, Converter={StaticResource BoolToVisibility}}">
              <Grid>
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="Auto" />
                  <ColumnDefinition Width="*" />
                  <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <ui:SymbolIcon
                  Grid.Column="0"
                  Margin="0,0,10,0"
                  VerticalAlignment="Center"
                  Foreground="{DynamicResource GoldAccentBrush}"
                  Symbol="Info24" />
                <TextBlock
                  Grid.Column="1"
                  VerticalAlignment="Center"
                  Text="{x:Static res:Strings.Editor_PhotorealNotReadyHint}"
                  TextWrapping="Wrap" />
                <ui:Button
                  Grid.Column="2"
                  Margin="12,0,0,0"
                  VerticalAlignment="Center"
                  Command="{Binding OpenPresenterSettingsCommand}"
                  Content="{x:Static res:Strings.Editor_OpenSettings}" />
              </Grid>
            </Border>
          </StackPanel>
        </Border>

        <!-- Script card -->
        <Border Margin="0,14,0,0" Style="{StaticResource CardBorder}">
          <StackPanel>
            <TextBlock Style="{StaticResource FieldLabelBase}" Text="{x:Static res:Strings.Editor_PasteLabel}" />
            <TextBlock
              Margin="1,0,0,8"
              Style="{StaticResource HintText}"
              Text="{x:Static res:Strings.Editor_ScriptHint}" />
            <ui:TextBox
              Height="150"
              AcceptsReturn="True"
              Text="{Binding PasteText, UpdateSourceTrigger=PropertyChanged}"
              TextWrapping="Wrap"
              VerticalScrollBarVisibility="Auto" />
            <StackPanel Margin="0,10,0,0" Orientation="Horizontal">
              <ui:Button
                Command="{Binding ImportCommand}"
                Content="{x:Static res:Strings.Editor_Import}"
                Icon="{ui:SymbolIcon TextBulletListLtr24}" />
              <ui:Button
                Margin="8,0,0,0"
                Appearance="Transparent"
                Command="{Binding LoadExampleCommand}"
                Content="{x:Static res:Strings.Editor_LoadExample}"
                Icon="{ui:SymbolIcon DocumentText24}" />
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Segments -->
        <Grid Margin="1,26,0,12">
          <TextBlock
            VerticalAlignment="Center"
            FontFamily="{DynamicResource DisplayFontFamily}"
            FontSize="20"
            FontWeight="Medium"
            Text="{x:Static res:Strings.Editor_Segments}" />
          <ui:Button
            HorizontalAlignment="Right"
            Command="{Binding AddSegmentCommand}"
            Content="{x:Static res:Strings.Editor_AddSegment}"
            Icon="{ui:SymbolIcon Add24}" />
        </Grid>

        <ItemsControl ItemsSource="{Binding Segments}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:SegmentViewModel}">
              <Border Margin="0,0,0,12" Style="{StaticResource CardBorder}">
                <StackPanel>
                  <Grid Margin="0,0,0,10">
                    <StackPanel Orientation="Horizontal">
                      <Rectangle
                        Width="3"
                        Height="16"
                        VerticalAlignment="Center"
                        Fill="{DynamicResource GoldAccentBrush}"
                        RadiusX="1.5"
                        RadiusY="1.5" />
                      <TextBlock
                        Margin="9,0,0,0"
                        VerticalAlignment="Center"
                        FontWeight="SemiBold"
                        Text="{Binding DisplayName}" />
                    </StackPanel>
                    <ui:Button
                      HorizontalAlignment="Right"
                      Appearance="Transparent"
                      Command="{Binding DataContext.RemoveSegmentCommand, ElementName=Root}"
                      CommandParameter="{Binding}"
                      Icon="{ui:SymbolIcon Delete24}"
                      ToolTip="{x:Static res:Strings.Common_Delete}" />
                  </Grid>

                  <TextBlock Style="{StaticResource FieldLabelBase}" Text="{x:Static res:Strings.Editor_HeadlineLabel}" />
                  <ui:TextBox Text="{Binding Headline, UpdateSourceTrigger=PropertyChanged}" />

                  <TextBlock
                    Margin="1,12,0,6"
                    Style="{StaticResource FieldLabelBase}"
                    Text="{x:Static res:Strings.Editor_BodyLabel}" />
                  <ui:TextBox
                    MinHeight="90"
                    AcceptsReturn="True"
                    Text="{Binding Body, UpdateSourceTrigger=PropertyChanged}"
                    TextWrapping="Wrap"
                    VerticalScrollBarVisibility="Auto" />

                  <Grid Margin="0,12,0,0">
                    <StackPanel Orientation="Horizontal" Visibility="{Binding HasImage, Converter={StaticResource InverseBoolToVisibility}}">
                      <ui:Button
                        Command="{Binding PickImageCommand}"
                        Content="{x:Static res:Strings.Editor_PickImage}"
                        Icon="{ui:SymbolIcon Image24}" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Visibility="{Binding HasImage, Converter={StaticResource BoolToVisibility}}">
                      <Border
                        Width="72"
                        Height="40"
                        VerticalAlignment="Center"
                        CornerRadius="5">
                        <Border.Clip>
                          <RectangleGeometry
                            RadiusX="5"
                            RadiusY="5"
                            Rect="0,0,72,40" />
                        </Border.Clip>
                        <Image Source="{Binding ImagePath}" Stretch="UniformToFill" />
                      </Border>
                      <TextBlock
                        Margin="12,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding ImageFile}" />
                      <ui:Button
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        Appearance="Transparent"
                        Command="{Binding RemoveImageCommand}"
                        Content="{x:Static res:Strings.Editor_RemoveImage}"
                        Icon="{ui:SymbolIcon Dismiss24}" />
                    </StackPanel>
                  </Grid>
                </StackPanel>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</UserControl>
