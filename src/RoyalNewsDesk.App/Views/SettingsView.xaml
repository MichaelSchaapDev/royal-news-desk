<UserControl
  x:Class="RoyalNewsDesk.App.Views.SettingsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:res="clr-namespace:RoyalNewsDesk.App.Resources"
  TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
  <UserControl.Resources>
    <Style x:Key="SectionBorder" TargetType="Border">
      <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
      <Setter Property="BorderBrush" Value="{DynamicResource CardStrokeColorDefaultBrush}" />
      <Setter Property="BorderThickness" Value="1" />
      <Setter Property="CornerRadius" Value="8" />
      <Setter Property="Padding" Value="18,14" />
      <Setter Property="Margin" Value="0,0,0,14" />
    </Style>
    <Style x:Key="SectionHeader" TargetType="TextBlock">
      <Setter Property="FontSize" Value="16" />
      <Setter Property="FontWeight" Value="SemiBold" />
      <Setter Property="Margin" Value="0,0,0,10" />
    </Style>
    <Style x:Key="FieldLabel" TargetType="TextBlock">
      <Setter Property="Margin" Value="0,10,0,4" />
    </Style>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="720" Margin="28,20,28,28" HorizontalAlignment="Stretch">
      <TextBlock
        Margin="0,0,0,16"
        FontSize="26"
        FontWeight="SemiBold"
        Text="{x:Static res:Strings.Settings_Header}" />

      <Border Style="{StaticResource SectionBorder}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static res:Strings.Settings_Language}" />
          <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding Language}">
            <ComboBoxItem Content="Nederlands" Tag="nl" />
            <ComboBoxItem Content="English" Tag="en" />
          </ComboBox>
          <StackPanel
            Margin="0,10,0,0"
            Orientation="Horizontal"
            Visibility="{Binding ShowRestartHint, Converter={StaticResource BoolToVisibility}}">
            <TextBlock
              VerticalAlignment="Center"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="{x:Static res:Strings.Settings_RestartHint}" />
            <ui:Button
              Margin="12,0,0,0"
              Command="{Binding RestartNowCommand}"
              Content="{x:Static res:Strings.Settings_RestartNow}" />
          </StackPanel>

          <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_Theme}" />
          <ui:ToggleSwitch
            IsChecked="{Binding IsDarkTheme}"
            OffContent="{x:Static res:Strings.Settings_ThemeLight}"
            OnContent="{x:Static res:Strings.Settings_ThemeDark}" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource SectionBorder}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static res:Strings.Settings_Voice}" />
          <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_ReadingSpeed}" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Slider
              Grid.Column="0"
              IsSnapToTickEnabled="True"
              Maximum="1.3"
              Minimum="0.8"
              TickFrequency="0.05"
              Value="{Binding ReadingSpeed}" />
            <TextBlock
              Grid.Column="1"
              Margin="12,0,0,0"
              VerticalAlignment="Center"
              Text="{Binding ReadingSpeed, StringFormat={}{0:0.00}}" />
          </Grid>
          <TextBlock
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            FontSize="12"
            Text="{x:Static res:Strings.Settings_ReadingSpeedHint}" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource SectionBorder}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static res:Strings.Settings_Branding}" />
          <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_ChannelName}" />
          <ui:TextBox Text="{Binding ChannelName, UpdateSourceTrigger=PropertyChanged}" />
          <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_Tagline}" />
          <ui:TextBox Text="{Binding Tagline, UpdateSourceTrigger=PropertyChanged}" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_PrimaryColor}" />
              <ui:TextBox Text="{Binding PrimaryColor, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_AccentColor}" />
              <ui:TextBox Text="{Binding AccentColor, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource SectionBorder}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static res:Strings.Settings_Production}" />
          <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_OutputFolder}" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" IsReadOnly="True" Text="{Binding OutputFolder}" />
            <ui:Button
              Grid.Column="1"
              Margin="8,0,0,0"
              Command="{Binding BrowseOutputFolderCommand}"
              Content="{x:Static res:Strings.Settings_Browse}"
              Icon="{ui:SymbolIcon Folder24}" />
          </Grid>

          <CheckBox
            Margin="0,12,0,0"
            Content="{x:Static res:Strings.Settings_BurnInSubtitles}"
            IsChecked="{Binding BurnInSubtitles}" />
          <CheckBox
            Margin="0,6,0,0"
            Content="{x:Static res:Strings.Settings_StudioAmbience}"
            IsChecked="{Binding StudioAmbience}" />
          <CheckBox
            Margin="0,6,0,0"
            Content="{x:Static res:Strings.Settings_HigherQuality}"
            IsChecked="{Binding HigherQuality}" />
          <CheckBox
            Margin="0,6,0,0"
            Content="{x:Static res:Strings.Settings_KeepWorkFiles}"
            IsChecked="{Binding KeepWorkFiles}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
