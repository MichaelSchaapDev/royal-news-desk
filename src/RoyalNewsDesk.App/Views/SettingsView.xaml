<UserControl
  x:Class="RoyalNewsDesk.App.Views.SettingsView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:res="clr-namespace:RoyalNewsDesk.App.Resources"
  xmlns:vm="clr-namespace:RoyalNewsDesk.App.ViewModels"
  TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
  <UserControl.Resources>
    <Style x:Key="SectionBorder" BasedOn="{StaticResource CardBorder}" TargetType="Border">
      <Setter Property="Margin" Value="0,0,0,14" />
    </Style>
    <Style x:Key="SectionHeader" BasedOn="{StaticResource SectionLabel}" TargetType="TextBlock">
      <Setter Property="Margin" Value="0,0,0,12" />
    </Style>
    <Style x:Key="FieldLabel" BasedOn="{StaticResource FieldLabelBase}" TargetType="TextBlock">
      <Setter Property="Margin" Value="1,14,0,6" />
    </Style>
  </UserControl.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel MaxWidth="760" Margin="44,26,44,44" HorizontalAlignment="Stretch">
      <StackPanel Margin="0,0,0,20">
        <TextBlock Style="{StaticResource PageKicker}" Text="{x:Static res:Strings.Brand_Studio}" />
        <TextBlock Style="{StaticResource PageTitle}" Text="{x:Static res:Strings.Settings_Header}" />
      </StackPanel>

      <Border Style="{StaticResource SectionBorder}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static res:Strings.Settings_Language}" />
          <ComboBox SelectedValuePath="Tag" SelectedValue="{Binding Language}">
            <ComboBoxItem Content="Nederlands" Tag="nl" />
            <ComboBoxItem Content="English" Tag="en" />
          </ComboBox>
          <StackPanel
            Margin="0,10,0,0"
            Orientation="Horizontal"
            Visibility="{Binding ShowRestartHint, Converter={StaticResource BoolToVisibility}}">
            <TextBlock
              VerticalAlignment="Center"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="{x:Static res:Strings.Settings_RestartHint}" />
            <ui:Button
              Margin="12,0,0,0"
              Command="{Binding RestartNowCommand}"
              Content="{x:Static res:Strings.Settings_RestartNow}" />
          </StackPanel>

          <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_Theme}" />
          <ui:ToggleSwitch
            IsChecked="{Binding IsDarkTheme}"
            OffContent="{x:Static res:Strings.Settings_ThemeLight}"
            OnContent="{x:Static res:Strings.Settings_ThemeDark}" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource SectionBorder}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static res:Strings.Settings_Voice}" />

          <ItemsControl ItemsSource="{Binding Voices}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type vm:VoiceOptionViewModel}">
                <Grid Margin="0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <RadioButton
                      Content="{Binding DisplayName}"
                      GroupName="VoicePick"
                      IsChecked="{Binding IsSelected}" />
                    <StackPanel Margin="28,0,0,0" Orientation="Horizontal">
                      <TextBlock FontSize="12" Text="{Binding StatusText}">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                      <TextBlock
                        Margin="10,0,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding SizeText}" />
                    </StackPanel>
                    <ProgressBar
                      Height="4"
                      Margin="28,4,0,0"
                      Maximum="1"
                      Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                      Value="{Binding ProgressFraction, Mode=OneWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                    <ui:Button
                      Command="{Binding DownloadCommand}"
                      Content="{x:Static res:Strings.Settings_VoiceDownload}"
                      Icon="{ui:SymbolIcon ArrowDownload24}"
                      IsEnabled="{Binding CanDownload}"
                      Visibility="{Binding IsInstalled, Converter={StaticResource InverseBoolToVisibility}}" />
                    <ui:Button
                      Command="{Binding DeleteCommand}"
                      Content="{x:Static res:Strings.Settings_VoiceDelete}"
                      IsEnabled="{Binding CanDelete}"
                      Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibility}}" />
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_ReadingSpeed}" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <Slider
              Grid.Column="0"
              IsSnapToTickEnabled="True"
              Maximum="1.3"
              Minimum="0.8"
              TickFrequency="0.05"
              Value="{Binding ReadingSpeed}" />
            <TextBlock
              Grid.Column="1"
              Margin="12,0,0,0"
              VerticalAlignment="Center"
              Text="{Binding ReadingSpeed, StringFormat={}{0:0.00}}" />
          </Grid>
          <TextBlock
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            FontSize="12"
            Text="{x:Static res:Strings.Settings_ReadingSpeedHint}" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource SectionBorder}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static res:Strings.Settings_Presenter}" />
          <TextBlock
            Margin="0,0,0,10"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="{x:Static res:Strings.Settings_PresenterIntro}"
            TextWrapping="Wrap" />

          <ItemsControl ItemsSource="{Binding PresenterEngines}">
            <ItemsControl.ItemTemplate>
              <DataTemplate DataType="{x:Type vm:PresenterEngineOptionViewModel}">
                <Grid Margin="0,4">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>
                  <StackPanel Grid.Column="0" VerticalAlignment="Center">
                    <RadioButton
                      Content="{Binding DisplayName}"
                      GroupName="PresenterEnginePick"
                      IsChecked="{Binding IsSelected}" />
                    <StackPanel Margin="28,0,0,0" Orientation="Horizontal">
                      <TextBlock FontSize="12" Text="{Binding StatusText}">
                        <TextBlock.Style>
                          <Style TargetType="TextBlock">
                            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding IsInstalled}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}" />
                                <Setter Property="FontWeight" Value="SemiBold" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </TextBlock.Style>
                      </TextBlock>
                      <TextBlock
                        Margin="10,0,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding SizeText}" />
                      <Border
                        Margin="10,0,0,0"
                        Style="{StaticResource ChipBorder}"
                        Visibility="{Binding NeedsGpu, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Style="{StaticResource ChipText}" Text="{x:Static res:Strings.Settings_EngineNeedsGpu}" />
                      </Border>
                      <TextBlock
                        Margin="10,0,0,0"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding BusyText}" />
                    </StackPanel>
                    <ProgressBar
                      Height="4"
                      Margin="28,4,0,0"
                      Maximum="1"
                      Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibility}}"
                      Value="{Binding ProgressFraction, Mode=OneWay}" />
                  </StackPanel>
                  <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                    <ui:Button
                      Command="{Binding DownloadCommand}"
                      Content="{x:Static res:Strings.Settings_VoiceDownload}"
                      Icon="{ui:SymbolIcon ArrowDownload24}"
                      IsEnabled="{Binding CanDownload}"
                      Visibility="{Binding IsInstalled, Converter={StaticResource InverseBoolToVisibility}}" />
                    <ui:Button
                      Command="{Binding DeleteCommand}"
                      Content="{x:Static res:Strings.Settings_VoiceDelete}"
                      IsEnabled="{Binding CanDelete}"
                      Visibility="{Binding IsInstalled, Converter={StaticResource BoolToVisibility}}" />
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_Portrait}" />
          <StackPanel Orientation="Horizontal">
            <Border
              Width="96"
              Height="96"
              Background="{DynamicResource ControlFillColorSecondaryBrush}"
              BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              ClipToBounds="True">
              <Grid>
                <TextBlock
                  Margin="6"
                  HorizontalAlignment="Center"
                  VerticalAlignment="Center"
                  FontSize="11"
                  Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                  Text="{x:Static res:Strings.Settings_PortraitNone}"
                  TextAlignment="Center"
                  TextWrapping="Wrap"
                  Visibility="{Binding HasPortrait, Converter={StaticResource InverseBoolToVisibility}}" />
                <Border CornerRadius="8" Visibility="{Binding HasPortrait, Converter={StaticResource BoolToVisibility}}">
                  <Image Source="{Binding PortraitPath}" Stretch="UniformToFill" />
                </Border>
              </Grid>
            </Border>
            <StackPanel Margin="14,0,0,0" VerticalAlignment="Center">
              <ui:Button
                Command="{Binding BrowsePortraitCommand}"
                Content="{x:Static res:Strings.Settings_PortraitChoose}"
                Icon="{ui:SymbolIcon Person24}" />
              <ui:Button
                Margin="0,6,0,0"
                Command="{Binding RemovePortraitCommand}"
                Content="{x:Static res:Strings.Settings_PortraitRemove}"
                Visibility="{Binding HasPortrait, Converter={StaticResource BoolToVisibility}}" />
            </StackPanel>
          </StackPanel>
          <TextBlock
            Margin="0,8,0,0"
            FontSize="12"
            Foreground="{DynamicResource TextFillColorSecondaryBrush}"
            Text="{x:Static res:Strings.Settings_PortraitConsentHint}"
            TextWrapping="Wrap" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource SectionBorder}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static res:Strings.Settings_Storage}" />
          <TextBlock
            Margin="0,0,0,10"
            Style="{StaticResource HintText}"
            Text="{x:Static res:Strings.Settings_StorageIntro}" />
          <TextBlock Style="{StaticResource FieldLabelBase}" Text="{x:Static res:Strings.Settings_StorageCurrent}" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox
              Grid.Column="0"
              IsReadOnly="True"
              Text="{Binding AiStorageText, Mode=OneWay}" />
            <ui:Button
              Grid.Column="1"
              Margin="8,0,0,0"
              Command="{Binding BrowseAiStorageCommand}"
              Content="{x:Static res:Strings.Settings_Browse}"
              Icon="{ui:SymbolIcon Folder24}"
              IsEnabled="{Binding CanChangeAiStorage}" />
          </Grid>
          <ui:Button
            Margin="0,8,0,0"
            HorizontalAlignment="Left"
            Appearance="Transparent"
            Command="{Binding ResetAiStorageCommand}"
            Content="{x:Static res:Strings.Settings_StorageReset}"
            IsEnabled="{Binding CanChangeAiStorage}"
            Visibility="{Binding AiStorageIsCustom, Converter={StaticResource BoolToVisibility}}" />
          <StackPanel Margin="0,10,0,0" Visibility="{Binding IsMovingAi, Converter={StaticResource BoolToVisibility}}">
            <ProgressBar
              Height="4"
              Maximum="1"
              Value="{Binding AiMoveFraction, Mode=OneWay}" />
            <TextBlock
              Margin="0,6,0,0"
              FontSize="12"
              Foreground="{DynamicResource TextFillColorSecondaryBrush}"
              Text="{x:Static res:Strings.Settings_StorageMoving}" />
          </StackPanel>
          <TextBlock
            Margin="0,8,0,0"
            FontSize="12"
            Foreground="{DynamicResource PaletteRedBrush}"
            Text="{Binding AiStorageError}"
            TextWrapping="Wrap"
            Visibility="{Binding AiStorageError, Converter={StaticResource NullToCollapsed}}" />
        </StackPanel>
      </Border>

      <Border Style="{StaticResource SectionBorder}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static res:Strings.Settings_Branding}" />
          <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_ChannelName}" />
          <ui:TextBox Text="{Binding ChannelName, UpdateSourceTrigger=PropertyChanged}" />
          <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_Tagline}" />
          <ui:TextBox Text="{Binding Tagline, UpdateSourceTrigger=PropertyChanged}" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="12" />
              <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_PrimaryColor}" />
              <ui:TextBox Text="{Binding PrimaryColor, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
            <StackPanel Grid.Column="2">
              <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_AccentColor}" />
              <ui:TextBox Text="{Binding AccentColor, UpdateSourceTrigger=PropertyChanged}" />
            </StackPanel>
          </Grid>
        </StackPanel>
      </Border>

      <Border Style="{StaticResource SectionBorder}">
        <StackPanel>
          <TextBlock Style="{StaticResource SectionHeader}" Text="{x:Static res:Strings.Settings_Production}" />
          <TextBlock Style="{StaticResource FieldLabel}" Text="{x:Static res:Strings.Settings_OutputFolder}" />
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" />
              <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <ui:TextBox Grid.Column="0" IsReadOnly="True" Text="{Binding OutputFolder}" />
            <ui:Button
              Grid.Column="1"
              Margin="8,0,0,0"
              Command="{Binding BrowseOutputFolderCommand}"
              Content="{x:Static res:Strings.Settings_Browse}"
              Icon="{ui:SymbolIcon Folder24}" />
          </Grid>

          <CheckBox
            Margin="0,12,0,0"
            Content="{x:Static res:Strings.Settings_BurnInSubtitles}"
            IsChecked="{Binding BurnInSubtitles}" />
          <CheckBox
            Margin="0,6,0,0"
            Content="{x:Static res:Strings.Settings_StudioAmbience}"
            IsChecked="{Binding StudioAmbience}" />
          <CheckBox
            Margin="0,6,0,0"
            Content="{x:Static res:Strings.Settings_HigherQuality}"
            IsChecked="{Binding HigherQuality}" />
          <CheckBox
            Margin="0,6,0,0"
            Content="{x:Static res:Strings.Settings_KeepWorkFiles}"
            IsChecked="{Binding KeepWorkFiles}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</UserControl>
