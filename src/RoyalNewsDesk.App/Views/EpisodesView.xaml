<UserControl
  x:Class="RoyalNewsDesk.App.Views.EpisodesView"
  xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
  xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
  xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
  xmlns:res="clr-namespace:RoyalNewsDesk.App.Resources"
  xmlns:vm="clr-namespace:RoyalNewsDesk.App.ViewModels"
  x:Name="Root"
  TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
  <Grid Margin="{StaticResource PagePadding}">
    <Grid
      HorizontalAlignment="Stretch"
      MaxWidth="{StaticResource ContentMaxWidth}">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto" />
        <RowDefinition Height="*" />
      </Grid.RowDefinitions>

      <!-- Header -->
      <Grid Grid.Row="0" Margin="0,0,0,22">
        <StackPanel>
          <TextBlock Style="{StaticResource PageKicker}" Text="{x:Static res:Strings.Episodes_Kicker}" />
          <TextBlock Style="{StaticResource PageTitle}" Text="{x:Static res:Strings.Episodes_Header}" />
        </StackPanel>
        <ui:Button
          HorizontalAlignment="Right"
          VerticalAlignment="Bottom"
          Appearance="Primary"
          Command="{Binding NewEpisodeCommand}"
          Content="{x:Static res:Strings.Episodes_New}"
          Icon="{ui:SymbolIcon Add24}"
          Visibility="{Binding IsEmpty, Converter={StaticResource InverseBoolToVisibility}}" />
      </Grid>

      <!-- Empty state -->
      <StackPanel
        Grid.Row="1"
        Margin="0,64,0,0"
        HorizontalAlignment="Center"
        VerticalAlignment="Top"
        Visibility="{Binding IsEmpty, Converter={StaticResource BoolToVisibility}}">
        <Path
          Width="44"
          Height="40"
          HorizontalAlignment="Center"
          Data="{StaticResource CrownGeometry}"
          Fill="{DynamicResource GoldAccentBrush}"
          Opacity="0.9"
          Stretch="Uniform" />
        <TextBlock
          Margin="0,18,0,0"
          HorizontalAlignment="Center"
          FontFamily="{DynamicResource DisplayFontFamily}"
          FontSize="22"
          FontWeight="Medium"
          Text="{x:Static res:Strings.Episodes_EmptyTitle}" />
        <TextBlock
          MaxWidth="400"
          Margin="0,8,0,0"
          HorizontalAlignment="Center"
          FontSize="13.5"
          Foreground="{DynamicResource TextFillColorSecondaryBrush}"
          Text="{x:Static res:Strings.Episodes_Empty}"
          TextAlignment="Center"
          TextWrapping="Wrap" />
        <ui:Button
          Margin="0,22,0,0"
          HorizontalAlignment="Center"
          Appearance="Primary"
          Command="{Binding NewEpisodeCommand}"
          Content="{x:Static res:Strings.Episodes_New}"
          Icon="{ui:SymbolIcon Add24}" />
      </StackPanel>

      <!-- Episode cards -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <ItemsControl ItemsSource="{Binding Episodes}">
          <ItemsControl.ItemTemplate>
            <DataTemplate DataType="{x:Type vm:EpisodeRow}">
              <Border Margin="0,0,0,12" Padding="14">
                <Border.Style>
                  <Style BasedOn="{StaticResource CardBorder}" TargetType="Border">
                    <Setter Property="Padding" Value="14" />
                    <Style.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="{DynamicResource CardHoverBrush}" />
                      </Trigger>
                    </Style.Triggers>
                  </Style>
                </Border.Style>
                <Grid>
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                  </Grid.ColumnDefinitions>

                  <!-- Thumbnail or crown placeholder -->
                  <Border
                    Grid.Column="0"
                    Width="118"
                    Height="66"
                    VerticalAlignment="Center"
                    CornerRadius="6">
                    <Border.Clip>
                      <RectangleGeometry
                        RadiusX="6"
                        RadiusY="6"
                        Rect="0,0,118,66" />
                    </Border.Clip>
                    <Grid>
                      <Border Visibility="{Binding HasThumbnail, Converter={StaticResource InverseBoolToVisibility}}">
                        <Border.Background>
                          <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Offset="0" Color="#243568" />
                            <GradientStop Offset="1" Color="#131F3E" />
                          </LinearGradientBrush>
                        </Border.Background>
                        <Path
                          Width="26"
                          Height="24"
                          HorizontalAlignment="Center"
                          VerticalAlignment="Center"
                          Data="{StaticResource CrownGeometry}"
                          Fill="{StaticResource BrandGoldBrush}"
                          Opacity="0.85"
                          Stretch="Uniform" />
                      </Border>
                      <Image
                        Source="{Binding ThumbnailPath, Converter={StaticResource PathToImage}}"
                        Stretch="UniformToFill"
                        Visibility="{Binding HasThumbnail, Converter={StaticResource BoolToVisibility}}" />
                    </Grid>
                  </Border>

                  <!-- Title + meta -->
                  <StackPanel
                    Grid.Column="1"
                    Margin="18,0,12,0"
                    VerticalAlignment="Center">
                    <TextBlock
                      FontSize="15"
                      FontWeight="SemiBold"
                      Text="{Binding Title}"
                      TextTrimming="CharacterEllipsis" />
                    <StackPanel Margin="0,7,0,0" Orientation="Horizontal">
                      <Border>
                        <Border.Style>
                          <Style BasedOn="{StaticResource ChipBorder}" TargetType="Border">
                            <Style.Triggers>
                              <DataTrigger Binding="{Binding HasOutput}" Value="True">
                                <Setter Property="Background" Value="{DynamicResource StatusGoodSoftBrush}" />
                              </DataTrigger>
                            </Style.Triggers>
                          </Style>
                        </Border.Style>
                        <TextBlock Text="{Binding StatusText}">
                          <TextBlock.Style>
                            <Style BasedOn="{StaticResource ChipText}" TargetType="TextBlock">
                              <Style.Triggers>
                                <DataTrigger Binding="{Binding HasOutput}" Value="True">
                                  <Setter Property="Foreground" Value="{DynamicResource StatusGoodBrush}" />
                                </DataTrigger>
                              </Style.Triggers>
                            </Style>
                          </TextBlock.Style>
                        </TextBlock>
                      </Border>
                      <TextBlock
                        Margin="10,0,0,0"
                        VerticalAlignment="Center"
                        FontSize="12"
                        Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                        Text="{Binding CreatedText}" />
                    </StackPanel>
                  </StackPanel>

                  <!-- Actions -->
                  <StackPanel
                    Grid.Column="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <ui:Button
                      Margin="0,0,6,0"
                      Command="{Binding DataContext.OpenCommand, ElementName=Root}"
                      CommandParameter="{Binding}"
                      Content="{x:Static res:Strings.Episodes_Open}"
                      Icon="{ui:SymbolIcon Open24}" />
                    <ui:Button
                      Appearance="Transparent"
                      Command="{Binding DataContext.DeleteCommand, ElementName=Root}"
                      CommandParameter="{Binding}"
                      Icon="{ui:SymbolIcon Delete24}"
                      ToolTip="{x:Static res:Strings.Common_Delete}" />
                  </StackPanel>
                </Grid>
              </Border>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </ScrollViewer>
    </Grid>
  </Grid>
</UserControl>
