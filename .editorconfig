root = true

[*]
charset = utf-8
insert_final_newline = true
indent_style = space
indent_size = 4
trim_trailing_whitespace = true

[*.{yml,yaml,json,xml,xaml,csproj,props,targets,manifest}]
indent_size = 2

[*.cs]
csharp_style_namespace_declarations = file_scoped:warning

# Culture safety: the target machine runs a Dutch locale. Any number or string
# operation that silently uses the current culture is a bug waiting to corrupt
# ffmpeg arguments, ffconcat durations, or SRT timestamps.
dotnet_diagnostic.CA1304.severity = error
dotnet_diagnostic.CA1305.severity = error
dotnet_diagnostic.CA1310.severity = error
dotnet_diagnostic.CA1311.severity = error
